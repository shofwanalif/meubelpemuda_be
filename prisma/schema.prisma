generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id            String    @id
  name          String    @db.Text
  email         String
  emailVerified Boolean   @default(false)
  image         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  role       String?   @db.Text
  banned     Boolean?  @default(false)
  banReason  String?   @db.Text
  banExpires DateTime?

  employeeBranch EmployeeBranch?
  sales          Sale[]
  priceUpdates   ProductPrice[]  @relation("UpdatedBy")

  deletedAt     DateTime?  

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.Text
  userAgent String?  @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String? @db.Text

  @@unique([token])
  @@index([userId(length: 191)])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId(length: 191)])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier(length: 191)])
  @@map("verification")
}

// =============================================================
// TABEL KUSTOM APLIKASI
// =============================================================

  model Branch {
    id        String   @id @default(cuid())
    name      String
    address   String?
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    deletedAt DateTime?

    // Relations
    employeeBranches EmployeeBranch[]
    // productPrices    ProductPrice[]
    categories       Category[]
    products         Product[]
    sales            Sale[]

    @@map("branch")
  }

  // Tabel pivot: karyawan <-> cabang (1 karyawan, 1 cabang aktif)
  model EmployeeBranch {
    id         String   @id @default(cuid())
    assignedAt DateTime @default(now())

    userId   String @unique // unique: 1 karyawan hanya boleh di 1 cabang
    user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    branchId String
    branch   Branch @relation(fields: [branchId], references: [id])

    @@map("employee_branch")
  }

model Category {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  products Product[]

  @@map("category")
}

model Product {
  id          String    @id @default(cuid())
  name        String
  description String?
  // unit        String    @default("pcs") // pcs, set, unit, dll
  stock       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  branchId    String
  branch      Branch @relation(fields: [branchId], references: [id])

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  
  prices    ProductPrice[]
  saleItems SaleItem[]

  @@map("product")
}

// Harga per cabang dengan riwayat perubahan
// branchId nullable = harga global (fallback jika cabang tidak punya harga sendiri)
model ProductPrice {
  id            String   @id @default(cuid())
  costPrice     Decimal  @db.Decimal(15, 2) // harga modal
  sellPrice     Decimal  @db.Decimal(15, 2) // harga jual
  effectiveFrom DateTime @default(now()) // diisi otomatis sistem, bukan user
  createdAt     DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  updatedById String
  updatedBy   User   @relation("UpdatedBy", fields: [updatedById], references: [id])

  @@map("product_price")
}

// Header transaksi penjualan (1 nota)
enum SaleStatus {
  COMPLETED
  CANCELLED
}

model Sale {
  id        String     @id @default(cuid())
  saleDate  DateTime   @default(now())
  status    SaleStatus @default(COMPLETED)
  notes     String?
  createdAt DateTime   @default(now())

  // data pelanggan
  customerName    String?
  customerAddress String?
  customerPhone   String?

  branchId    String
  branch      Branch @relation(fields: [branchId], references: [id])
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  // Relations
  items SaleItem[]

  @@map("sale")
}

// Detail item per transaksi - harga di-snapshot saat transaksi
model SaleItem {
  id                String  @id @default(cuid())
  qty               Int     
  sellPriceSnapshot Decimal @db.Decimal(15, 2) // harga jual saat transaksi
  discountAmount    Decimal? @default(0) @db.Decimal(15, 2) 
  costPriceSnapshot Decimal @db.Decimal(15, 2) // harga modal saat transaksi
  totalSell         Decimal @db.Decimal(15, 2) // sellPriceSnapshot * qty
  grossProfit       Decimal @db.Decimal(15, 2) // (sellPrice - costPrice) * qty

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@map("sale_item")
}
